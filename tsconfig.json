{
  "extends": "astro/tsconfigs/strict",
  "include": [
    "src"
  ],
  "exclude": [
    "dist"
  ],
  "compilerOptions": {
    "declaration": true,
    "emitDeclarationOnly": true,
    "outDir": "dist",
    "declarationMap": true,
    "skipLibCheck": true,
    "moduleResolution": "Bundler",
    "module": "ESNext",
    "target": "ESNext",
    "isolatedModules": true
  }
}